DJANGO_SECRET_KEY=change-me-in-real-env
DJANGO_DEBUG=True
POSTGRES_DB=ashantihub
POSTGRES_USER=ashantihub
POSTGRES_PASSWORD=ashantihub_dev
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Email — defaults to the console backend (prints emails to the runserver
# log) when unset, so dev works with no SMTP setup. Set these in production
# (e.g. an authenticated cPanel mailbox) to actually deliver mail.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=change-me-never-commit-a-real-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@theashantihub.com

# Public base URL of the deployed frontend — used to build Hubtel's
# returnUrl/cancellationUrl. Defaults to the local Vite dev server.
FRONTEND_BASE_URL=http://localhost:5173

# Hubtel payments (docs/HUBTEL_INTEGRATION.md) — leave every one of these
# blank to keep every payment flow running in simulated mode (today's
# instant-success behavior, zero gateway involved). Setting HUBTEL_CLIENT_ID
# is what flips settings.PAYMENTS_PROVIDER to "hubtel" and activates real
# Hubtel Checkout — no code change needed for that flip, just restart the
# app once these are filled in. Sandbox and production credentials are
# separate; do not fill these in until real Hubtel merchant credentials
# (sandbox first, then production) are in hand. The webhook signature
# verification in payments/hubtel_client.py is UNVERIFIED against real
# Hubtel docs — confirm it before ever setting these in production.
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_MERCHANT_ACCOUNT=
HUBTEL_WEBHOOK_SECRET=
HUBTEL_CALLBACK_URL=

# Deployment (production only — dev defaults keep working when unset):
# comma-separated Host headers Django will accept, e.g. api.theashantihub.com
DJANGO_ALLOWED_HOSTS=
# set False in production and list the real frontend origins below
DJANGO_CORS_ALLOW_ALL_ORIGINS=True
DJANGO_CORS_ALLOWED_ORIGINS=
