{
  "mcpServers": {
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic@latest"],
      "env": {
        "API_KEY": "YOUR_21ST_DEV_API_KEY_HERE"
      }
    },
    "postgres": {
      "command": "uvx",
      "args": ["--python", "3.12", "postgres-mcp", "--access-mode=unrestricted"],
      "env": {
        "DATABASE_URI": "postgresql://ashantihub:ashantihub_dev@localhost:5432/ashantihub"
      }
    },
    "semgrep": {
      "command": "uvx",
      "args": ["--python", "3.12", "semgrep-mcp"],
      "env": {
        "SEMGREP_MCP_DISABLE_TRACING": "true"
      }
    }
  }
}
